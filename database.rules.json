{
    "rules": {
        "quotes": {
            ".read": true,
            ".write": true,
            ".indexOn": "type",
            "$quoteId": {
                ".validate": "newData.hasChildren(['text', 'type', 'createdAt', 'likes', 'visible'])",
                "likes": {
                    ".write": true,
                    ".validate": "newData.isNumber()"
                },
                "savedBy": {
                    ".write": true,
                    ".validate": "newData.val() === 'user_like'"
                }
            }
        },
        "sessions": {
            ".read": "auth !== null",
            "$sessionId": {
                ".read": true,
                ".write": true,
                ".validate": "newData.hasChildren(['sessionId', 'startedAt', 'lastSeen'])",
                "sessionId": {
                    ".validate": "newData.isString()"
                },
                "startedAt": {
                    ".validate": "newData.isNumber()"
                },
                "lastSeen": {
                    ".validate": "newData.isNumber()"
                },
                "scrollCount": {
                    ".validate": "!newData.exists() || newData.isNumber()"
                },
                "likeCount": {
                    ".validate": "!newData.exists() || newData.isNumber()"
                },
                "durationSeconds": {
                    ".validate": "!newData.exists() || newData.isNumber()"
                },
                "$other": {
                    ".validate": false
                }
            }
        },
        "stats": {
            ".read": true,
            ".write": true,
            ".validate": "newData.hasChildren(['totalUsers'])",
            "$stat": {
                ".validate": "newData.isNumber()"
            }
        }
    }
}